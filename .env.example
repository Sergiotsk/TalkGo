# TalkGo — Environment Variables
# Copy this file to .env and fill in the values before starting the stack.
# Lines marked "# REQUIRED" must be set; the server will fail to start without them.
# Lines with a default shown are optional — the default is used when the var is unset.

# ── OpenAI ───────────────────────────────────────────────────────────────────

# OpenAI API key for the Realtime translation service.
# REQUIRED
OPENAI_API_KEY=sk-...

# ── Server ───────────────────────────────────────────────────────────────────

# TCP port the talkgo HTTP/WebSocket server listens on inside the container.
# Default: 8080
PORT=8080

# Log verbosity level. Accepted values: debug | info | warn | error
# Default: info
LOG_LEVEL=info

# Audio codec to use for the translation pipeline.
# Accepted values: opus | passthrough
# Use "passthrough" for development/testing without audio encoding overhead.
# Default: opus
CODEC_MODE=opus

# ── TURN / ICE ───────────────────────────────────────────────────────────────

# Comma-separated list of TURN server URLs.
# Leave empty to use STUN-only mode (NAT traversal may fail for strict NATs).
# Example: turn:your-server.example.com:3478,turns:your-server.example.com:5349
# Default: (empty — STUN only)
TURN_URLS=turn:your-server.example.com:3478

# TURN server credentials.
# These must match the user/password configured in deploy/coturn/turnserver.conf.
# REQUIRED if TURN_URLS is set.
TURN_USERNAME=talkgo
TURN_PASSWORD=CHANGEME_TURN_PASSWORD

# ── Rate Limiting ─────────────────────────────────────────────────────────────

# Maximum number of room creation requests (POST /rooms) per client per minute.
# Set to 0 to disable rate limiting for this endpoint.
# Default: 10
RATE_LIMIT_ROOMS=10

# Maximum number of WebSocket upgrade requests (GET /ws/{roomID}) per client per minute.
# Set to 0 to disable rate limiting for this endpoint.
# Default: 20
RATE_LIMIT_WS=20

# ── Caddy / TLS ───────────────────────────────────────────────────────────────

# Public domain name for the deployment (used by Caddy for TLS certificate issuance).
# Example: talkgo.example.com
# REQUIRED for production deployments with HTTPS.
DOMAIN=talkgo.example.com

# Email address for Let's Encrypt ACME registration (TLS certificate notifications).
# REQUIRED for production deployments with HTTPS.
ACME_EMAIL=admin@example.com

# ── Room Lifecycle ────────────────────────────────────────────────────────────

# Duration a room remains alive after all participants disconnect before it is deleted.
# Accepts Go duration strings: e.g. 30s, 5m, 1h
# Default: 30s
GRACE_PERIOD=30s

# Maximum lifetime of an inactive room (no participants ever joined or all left).
# Accepts Go duration strings.
# Default: 10m
ROOM_TTL=10m
